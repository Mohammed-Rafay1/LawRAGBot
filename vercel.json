{
  "version": 2,
  "builds": [
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lawragbot.onrender.com/api/:path*"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    }
  ]
}
